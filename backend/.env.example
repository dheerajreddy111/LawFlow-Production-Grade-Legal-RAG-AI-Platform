# ──────────────────────────────────────────────────────────────────────────
# LawFlow — backend environment template
# ──────────────────────────────────────────────────────────────────────────
# Copy to `backend/.env` for local development. Production deploys
# should inject these via your secret manager, never commit secrets.
# Anything that looks like a credential below is a *placeholder* —
# replace before deploying.

# ── Runtime ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Auth ──────────────────────────────────────────────────────────────────
# JWT_SECRET_KEY MUST be set in production. In dev a per-process random
# secret is synthesised when this is empty — tokens will not survive a
# restart, which is the desired behaviour locally.
# Generate a real one with:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Cookie flags for the refresh-token cookie. Set COOKIE_SECURE=true behind
# HTTPS.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=

# ── Bootstrap admin ───────────────────────────────────────────────────────
# Set both to provision the first admin on first start. The lifespan is
# idempotent — leaving these set on subsequent restarts is safe but the
# password is only read at creation time (rotation is *not* via this var).
# Generate a strong password out-of-band, e.g.:
#     python -c "import secrets; print(secrets.token_urlsafe(24))"
# WARNING: never use these placeholder values in production.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# ── Database ──────────────────────────────────────────────────────────────
# Defaults to a single-file SQLite under backend/. Swap for Postgres in
# production:
#     DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=sqlite+aiosqlite:///./lawflow.db

# ── LLM keys ──────────────────────────────────────────────────────────────
# Groq is used automatically when GROQ_API_KEY is set.
# WARNING: the value below is a *placeholder*. Replace before committing.
GROQ_API_KEY=your_groq_api_key_here
LANGCHAIN_API_KEY=your_langsmith_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
JWT_SECRET=replace_me

# ── Vector store ──────────────────────────────────────────────────────────
VECTOR_STORE_URL=

# ── Retrieval (hybrid / cross-encoder) ────────────────────────────────────
# Hybrid retrieval (BM25 + vector) is on by default. These knobs tune the
# fusion + variant + rerank stages. Defaults are calibrated against the
# bundled corpora; rerun the benchmark suite after changing them.
RAG_RETRIEVE_PER_VARIANT=12          # top-k each retriever surfaces per variant
RAG_FUSED_TOP_K=16                   # fused-list size handed to the reranker
RAG_W_VECTOR=0.6                     # RRF weight for the bi-encoder retriever
RAG_W_BM25=0.4                       # RRF weight for the lexical retriever
RAG_DEDUP_PENALTY=0.85               # demotion for chunks sharing source+section
# Cross-encoder reranker — opt-in. When enabled, BAAI/bge-reranker-base is
# downloaded on first use (~280MB) and scores (query, chunk) pairs after
# the deterministic legal-signal rerank.
CROSS_ENCODER_ENABLED=false
CROSS_ENCODER_MODEL=BAAI/bge-reranker-base
CROSS_ENCODER_MAX_PAIRS=32

# ── Retention / cleanup ───────────────────────────────────────────────────
# Periodic sweeps trim append-only tables. Each window is in days; set
# to 0 to disable that sweep. The stale-job reaper flags jobs left in
# `running` past the threshold as `failed` — they're orphans from a
# previous API process crash.
RETENTION_QUERY_EVENTS_DAYS=90
RETENTION_EVAL_RUNS_DAYS=180
RETENTION_JOBS_DAYS=30
STALE_JOB_RUNNING_HOURS=2
RETENTION_SWEEP_INTERVAL_HOURS=24

# ── LangChain / LangSmith / LangGraph (optional) ──────────────────────────
# Tracing is OFF by default. When enabled, every LangGraph node, retrieval
# stage (BM25, vector, rerank, cross-encoder), query rewrite, LLM call,
# evaluation run, and admin-triggered operation is captured as a nested
# span in your LangSmith project.
#
# PRIVACY: enabling tracing sends user queries, retrieved chunk text, and
# LLM responses to api.smith.langchain.com. This is fine for local
# debugging on synthetic data but is a non-trivial choice for any
# deployment touching real client questions — review your data-handling
# policy before flipping these on in production. Tracing is off by
# default precisely so production deploys never accidentally leak data.
#
# To enable (local / staging recommended):
#   LANGCHAIN_TRACING_V2=true
#   LANGCHAIN_API_KEY=ls__<your-key>
# Without BOTH set, the integration layer is a cheap no-op (see
# app/integrations/lc/settings.py — `is_tracing_enabled()`).
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=lawflow
# Custom LangSmith host (self-hosted / EU region). Default is the SaaS
# endpoint https://api.smith.langchain.com.
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# Comma-separated tags applied to every span; handy for separating
# `local`, `staging`, and `ci` traces inside the same LangSmith project.
# LC_DEFAULT_TAGS=lawflow,backend
#
# Route RAG queries through the LangGraph graph (opt-in, Phase 4).
# Deterministic routing is unaffected — only RAG-routed queries change path.
RAG_USE_LANGGRAPH=false
